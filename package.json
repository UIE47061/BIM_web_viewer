{
  "name": "bim-web-viewer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "copy-wasm": "mkdir -p public/wasm && cp node_modules/web-ifc/*.wasm public/wasm/ && cp node_modules/web-ifc/*.worker.js public/ && cp node_modules/web-ifc/*.worker.js public/wasm/",
    "postinstall": "npm run copy-wasm"
  },
  "dependencies": {
    "@mdi/js": "^7.4.0",
    "pinia": "^2.1.0",
    "three": "^0.162.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "web-ifc": "^0.0.57"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/three": "^0.162.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "~5.3.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.0.0"
  }
}
